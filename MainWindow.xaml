<Window x:Class="Calculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Calculator"
        Height="500"
        Width="300"
        MinWidth="350"
        Background="{StaticResource WindowBgBrush}"
        Foreground="{StaticResource TextBrush}"
        ResizeMode="CanResize">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin"
                    Value="3"/>
            <Setter Property="FontSize"
                    Value="20"/>
            <Setter Property="Cursor"
                    Value="Hand"/>
            <Setter Property="Background"
                    Value="{StaticResource NumberBtnBrush}"/>
            <Setter Property="Foreground"
                    Value="{StaticResource TextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="#555555"
                                BorderThickness="2"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#555555"/>
                                <Setter TargetName="border"
                                        Property="BorderBrush"
                                        Value="{StaticResource AccentBrush}"/>
                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#222222"/>
                                <Setter TargetName="border"
                                        Property="BorderThickness"
                                        Value="2"/>
                                <Setter TargetName="border"
                                        Property="BorderBrush"
                                        Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition x:Name="ScientificColumn"
                              Width="0"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0"
              Grid.Column="1"
              Grid.ColumnSpan="4"
              Grid.RowSpan="2"
              Margin="10,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <Viewbox Grid.Row="0"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Bottom">
                <TextBox x:Name="input"
                         Text="0"
                         FontSize="48"
                         Foreground="{StaticResource TextBrush}"
                         Background="Transparent"
                         CaretBrush="{StaticResource AccentBrush}"
                         BorderThickness="0"
                         TextAlignment="Right"
                         MinWidth="100"
                         KeyDown="Input_KeyDown"/>
            </Viewbox>

            <Viewbox Grid.Row="1"
                     HorizontalAlignment="Right"
                     VerticalAlignment="Top">
                <TextBlock x:Name="output"
                           Text=""
                           FontSize="20"
                           Foreground="Gray"
                           TextAlignment="Right"
                           Margin="0,0,5,0"
                           MinWidth="50"/>
            </Viewbox>
        </Grid>

        <Button Content="≡"
                Grid.Row="0"
                Grid.Column="0"
                Foreground="{StaticResource AccentBrush}"
                Click="ToggleScientific_Click"/>

        <Button Content="CE"
                Grid.Row="2"
                Grid.Column="0"
                Background="{StaticResource RedBrush}"
                Click="UndoButton_Click"/>

        <Button Content="C"
                Grid.Row="2"
                Grid.Column="1"
                Background="{StaticResource RedBrush}"
                BorderBrush="{StaticResource BrightRedBrush}"
                Click="ClearButton_Click"/>

        <Button Content="↻"
                Grid.Row="2"
                Grid.Column="2"
                Click="RedoButton_Click"/>

        <Button Content="⌫"
                Grid.Row="2"
                Grid.Column="3"
                Click="EraseButton_Click"/>

        <Button Content="Pi"
                Grid.Row="2"
                Grid.Column="4"
                Click="MathFunc_Click"/>

        <Button Content="("
                Grid.Row="3"
                Grid.Column="0"
                Click="InputButton_Click"/>

        <Button Content=")"
                Grid.Row="3"
                Grid.Column="1"
                Click="InputButton_Click"/>

        <Button Content="%"
                Grid.Row="3"
                Grid.Column="2"
                Click="InputButton_Click"/>

        <Button Content="/"
                Grid.Row="3"
                Grid.Column="3"
                Click="InputButton_Click"/>

        <Button Content="E"
                Grid.Row="3"
                Grid.Column="4"
                Click="MathFunc_Click"/>

        <Button Content="7"
                Grid.Row="4"
                Grid.Column="0"
                Click="InputButton_Click"/>

        <Button Content="8"
                Grid.Row="4"
                Grid.Column="1"
                Click="InputButton_Click"/>

        <Button Content="9"
                Grid.Row="4"
                Grid.Column="2"
                Click="InputButton_Click"/>

        <Button Content="*"
                Grid.Row="4"
                Grid.Column="3"
                Click="InputButton_Click"/>

        <Button Content="abs"
                Grid.Row="4"
                Grid.Column="4"
                Click="MathFunc_Click"/>

        <Button Content="4"
                Grid.Row="5"
                Grid.Column="0"
                Click="InputButton_Click"/>

        <Button Content="5"
                Grid.Row="5"
                Grid.Column="1"
                Click="InputButton_Click"/>

        <Button Content="6"
                Grid.Row="5"
                Grid.Column="2"
                Click="InputButton_Click"/>

        <Button Content="-"
                Grid.Row="5"
                Grid.Column="3"
                Click="InputButton_Click"/>

        <Button Content="sqrt"
                Grid.Row="5"
                Grid.Column="4"
                Click="MathFunc_Click"/>

        <Button Content="1"
                Grid.Row="6"
                Grid.Column="0"
                Click="InputButton_Click"/>

        <Button Content="2"
                Grid.Row="6"
                Grid.Column="1"
                Click="InputButton_Click"/>

        <Button Content="3"
                Grid.Row="6"
                Grid.Column="2"
                Click="InputButton_Click"/>

        <Button Content="+"
                Grid.Row="6"
                Grid.Column="3"
                Click="InputButton_Click"/>

        <Button Content="pow"
                Grid.Row="6"
                Grid.Column="4"
                Click="MathFunc_Click"/>

        <Button Content="00"
                Grid.Row="7"
                Grid.Column="0"
                Click="InputButton_Click"/>

        <Button Content="0"
                Grid.Row="7"
                Grid.Column="1"
                Click="InputButton_Click"/>

        <Button Content="."
                Grid.Row="7"
                Grid.Column="2"
                Click="InputButton_Click"/>

        <Button x:Name="btnEval"
                Content="="
                Grid.Row="7"
                Grid.Column="3"
                Background="{StaticResource GreenBrush}"
                IsDefault="True"
                Click="EvalButton_Click"/>

        <Button Content="log"
                Grid.Row="7"
                Grid.Column="4"
                Click="MathFunc_Click"/>
    </Grid>
</Window>
