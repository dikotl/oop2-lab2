<Window x:Class="Calculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Calculator" Height="400" Width="300"
        Background="{StaticResource WindowBgBrush}" 
        Foreground="{StaticResource TextBrush}">

    <Window.Resources>
        <Style TargetType="Button" x:Key="EqualsButtonStyle">
            <Setter Property="Margin" Value="3"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{StaticResource GreenBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{StaticResource BrightGreenBrush}" 
                                BorderThickness="3"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BrightGreenBrush}"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#555555"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#222222"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="3"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="3"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="{StaticResource NumberBtnBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="#555555" 
                                BorderThickness="3" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#555555"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#222222"/>
                                <Setter TargetName="border" Property="BorderThickness" Value="3"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="2*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4" Margin="10,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*" />
                <RowDefinition Height="1*" />
            </Grid.RowDefinitions>

            <Viewbox Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <TextBox x:Name="input" 
                         Text="0" 
                         FontSize="48" 
                         Foreground="{StaticResource TextBrush}" 
                         Background="Transparent"
                         CaretBrush="{StaticResource AccentBrush}"
                         BorderThickness="0"
                         TextAlignment="Right"
                         MinWidth="100"
                         KeyDown="input_KeyDown"/>
            </Viewbox>

            <Viewbox Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Top">
                <TextBlock x:Name="output" 
                   Text="" 
                   FontSize="20" 
                   Foreground="Gray" 
                   TextAlignment="Right" 
                   Margin="0,0,5,0"
                   MinWidth="50"/>
            </Viewbox>
        </Grid>

        <Button Content="7"
                Grid.Row="1"
                Grid.Column="0"
                Margin="2"
                FontSize="20"
                Click="NumberButton_Click"
                Background="{StaticResource NumberBtnBrush}" 
                Foreground="{StaticResource TextBrush}" 
                BorderThickness="0.5" 
                BorderBrush="#444"/>
        
        <Button Content="8"
                Grid.Row="1"
                Grid.Column="1"
                Margin="2"
                FontSize="20"
                Click="NumberButton_Click"
                Background="{StaticResource NumberBtnBrush}" 
                Foreground="{StaticResource TextBrush}" 
                BorderThickness="0.5" 
                BorderBrush="#444"/>
        
        <Button Content="9"
                Grid.Row="1"
                Grid.Column="2"
                Margin="2"
                FontSize="20"
                Click="NumberButton_Click"
                Background="{StaticResource NumberBtnBrush}" 
                Foreground="{StaticResource TextBrush}" 
                BorderThickness="0.5" 
                BorderBrush="#444"/>
        
        <Button Content="/"
                Grid.Row="1"
                Grid.Column="3"
                Margin="2"
                FontSize="20"
                Click="OperatorButton_Click"
                Background="{StaticResource NumberBtnBrush}" 
                Foreground="{StaticResource TextBrush}" 
                BorderThickness="0.5" 
                BorderBrush="#444"/>

        <Button Content="4"
                Grid.Row="2"
                Grid.Column="0"
                Margin="2"
                FontSize="20"
                Click="NumberButton_Click"
                Background="{StaticResource NumberBtnBrush}" 
                Foreground="{StaticResource TextBrush}" 
                BorderThickness="0.5" 
                BorderBrush="#444"/>

        <Button Content="5"
                Grid.Row="2"
                Grid.Column="1"
                Margin="2"
                FontSize="20"
                Click="NumberButton_Click"
                Background="{StaticResource NumberBtnBrush}" 
                Foreground="{StaticResource TextBrush}" 
                BorderThickness="0.5" 
                BorderBrush="#444"/>

        <Button Content="6"
                Grid.Row="2"
                Grid.Column="2"
                Margin="2"
                FontSize="20"
                Click="NumberButton_Click"
                Background="{StaticResource NumberBtnBrush}" 
                Foreground="{StaticResource TextBrush}" 
                BorderThickness="0.5" 
                BorderBrush="#444"/>

        <Button Content="*"
                Grid.Row="2"
                Grid.Column="3"
                Margin="2"
                FontSize="20"
                Click="OperatorButton_Click"
                Background="{StaticResource NumberBtnBrush}" 
                Foreground="{StaticResource TextBrush}" 
                BorderThickness="0.5" 
                BorderBrush="#444"/>

        <Button Content="1"
                Grid.Row="3"
                Grid.Column="0"
                Margin="2"
                FontSize="20"
                Click="NumberButton_Click"
                Background="{StaticResource NumberBtnBrush}" 
                Foreground="{StaticResource TextBrush}" 
                BorderThickness="0.5" 
                BorderBrush="#444"/>

        <Button Content="2"
                Grid.Row="3"
                Grid.Column="1"
                Margin="2"
                FontSize="20"
                Click="NumberButton_Click"
                Background="{StaticResource NumberBtnBrush}" 
                Foreground="{StaticResource TextBrush}" 
                BorderThickness="0.5" 
                BorderBrush="#444"/>

        <Button Content="3"
                Grid.Row="3"
                Grid.Column="2"
                Margin="2"
                FontSize="20"
                Click="NumberButton_Click"
                Background="{StaticResource NumberBtnBrush}" 
                Foreground="{StaticResource TextBrush}" 
                BorderThickness="0.5" 
                BorderBrush="#444"/>

        <Button Content="-"
                Grid.Row="3"
                Grid.Column="3"
                Margin="2"
                FontSize="20"
                Click="OperatorButton_Click"
                Background="{StaticResource NumberBtnBrush}" 
                Foreground="{StaticResource TextBrush}" 
                BorderThickness="0.5" 
                BorderBrush="#444"/>

        <Button Content="C"
                Grid.Row="4"
                Grid.Column="0"
                Margin="2"
                FontSize="20"
                Click="ClearButton_Click"
                Background="{StaticResource RedBrush}" 
                Foreground="{StaticResource TextBrush}" 
                BorderThickness="0.5" 
                BorderBrush="{StaticResource BrightRedBrush}"/>

        <Button Content="0"
                Grid.Row="4"
                Grid.Column="1"
                Margin="2"
                FontSize="20"
                Click="NumberButton_Click"
                Background="{StaticResource NumberBtnBrush}" 
                Foreground="{StaticResource TextBrush}" 
                BorderThickness="0.5" 
                BorderBrush="#444"/>

        <Button x:Name="btnEval"
                Content="="
                Grid.Row="4"
                Grid.Column="2"
                Margin="2"
                FontSize="20"
                Click="EqualsButton_Click"
                Background="{StaticResource GreenBrush}" 
                Foreground="Black" 
                BorderThickness="0.5" 
                BorderBrush="{StaticResource BrightGreenBrush}"
                IsDefault="True"
                Style="{StaticResource EqualsButtonStyle}"/>

        <Button Content="+"
                Grid.Row="4"
                Grid.Column="3"
                Margin="2"
                FontSize="20"
                Click="OperatorButton_Click"
                Background="{StaticResource NumberBtnBrush}" 
                Foreground="{StaticResource TextBrush}" 
                BorderThickness="0.5" 
                BorderBrush="#444"/>
    </Grid>
</Window>