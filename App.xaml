<Application x:Class="Calculator.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:Calculator"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBgBrush" Color="#202020" />
        <SolidColorBrush x:Key="DisplayBgBrush" Color="#2D2D2D" />
        <SolidColorBrush x:Key="TextBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="NumberBtnBrush" Color="#3B3B3B" />
        <SolidColorBrush x:Key="OpBtnBrush" Color="#323232" />
        <SolidColorBrush x:Key="AccentBrush" Color="#76B9FF" />
        <SolidColorBrush x:Key="GreenBrush" Color="#76d67e" />
        <SolidColorBrush x:Key="BrightGreenBrush" Color="#7da880" />
        <SolidColorBrush x:Key="RedBrush" Color="#d67676" />
        <SolidColorBrush x:Key="BrightRedBrush" Color="#eb6c6c" />
    </Application.Resources>
</Application>
